<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_project_custom_document">
        <t t-call="web.external_layout">
            <t t-if="o">
                <t t-set="o" t-value="o.with_context(lang=lang)"/>
                <div class="page" style="border:0; margin: 0; background-size:220mm 150mm; width:212mm; height:150mm;">
                    
                </div>
            </t>
        </t>
    </template>

    <template id="report_project_custom">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="lang" t-value="o.approval_id.lang"/>
                <t t-call="project_custom.report_project_custom_document" t-lang="lang"/>
            </t>
        </t>
    </template>
</odoo>
