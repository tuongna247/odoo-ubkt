<odoo>
    <!-- View approval page of the project_task -->
    <template id="project_task_portal_template" name="Project Task Portal Template" inherit_id="portal.portal_sidebar" primary="True">
        <xpath expr="//div[hasclass('o_portal_sidebar')]" position="inside">
            <div class="row mt16 o_portal_invoice_sidebar">
                <!-- Sidebar -->
                <t t-call="portal.portal_record_sidebar">
                    <t t-set="classes" t-value="'col-lg-auto d-print-none'"/>

                    <t t-set="title">
                        <h2 class="mb-0"><b t-field="project_task.name_seq" data-id="name_seq"/> </h2>
                    </t>
                    <t t-if="project_task.display_confirm()" t-set="entries">
                        <ul class="list-group list-group-flush flex-wrap flex-row flex-lg-column">
                            <li class="list-group-item flex-grow-1">
                                <t>
                                    <a role="button" class="btn btn-primary btn-block mb8" data-toggle="modal" data-target="#modalaccept" href="#">
                                        <i class="fa fa-check"/><t> Accept</t>
                                    </a>
                                </t>
                            </li>
                        </ul>
                    </t>
                </t>

                <!-- Page content -->
                <div id="project_task_approval_content" class="col-12 col-lg justify-content-end">

                    <!-- modal relative to the actions sign and pay -->
                    <div role="dialog" class="modal fade" id="modalaccept">
                        <div class="modal-dialog">
                            <form id="accept" method="POST" t-attf-action="/my/project_tasks/#{project_task.id}/accept?access_token=#{project_task.access_token}" class="modal-content">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <header class="modal-header">
                                    <h4 class="modal-title">Confirm Project</h4>
                                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">&amp;times;</button>
                                </header>
                                <main class="modal-body" id="sign-dialog">
                                    <p>
                                        <span>By confirming this proposal, I agree to the following terms:</span>
                                        <ul>
                                            <li><span>Accepted on the behalf of:</span> <b t-field="project_task.approval_id.partner_id.name"/></li>
                                            <li><span>For project code:</span> <b t-field="project_task.name_seq"/></li>
                                        </ul>
                                        <span>Please give your opinion about this project</span>
                                    </p>
                                    <textarea rows="6" name="approve_message" required="" placeholder="Your feedback..." class="form-control" />
                                </main>
                                <footer class="modal-footer">
                                    <button type="submit" t-att-id="project_task.id" class="btn btn-primary"><i class="fa fa-check"></i> Accept</button>
                                </footer>
                            </form>
                        </div>
                    </div>

                    <!-- modal relative to the action reject -->
                    <div role="dialog" class="modal fade" id="modaldecline">
                        <div class="modal-dialog">
                            <form id="decline" method="POST" t-attf-action="/my/project_tasks/#{project_task.id}/decline?access_token=#{project_task.access_token}" class="modal-content">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <header class="modal-header">
                                    <h4 class="modal-title">Reject Project</h4>
                                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">&amp;times;</button>
                                </header>
                                <main class="modal-body">
                                    <p>
                                        Please tell us why you are refusing this project, this will help us improve our services.
                                    </p>
                                    <textarea rows="6" name="decline_message" required="" placeholder="Your feedback..." class="form-control" />
                                </main>
                                <footer class="modal-footer">
                                    <button type="submit" t-att-id="project_task.id" class="btn btn-danger"><i class="fa fa-times"></i> Reject</button>
                                    <!-- <button type="button" class="btn btn-primary" data-dismiss="modal">Reject</button> -->
                                </footer>
                            </form>
                        </div>
                    </div>

                    <!-- status messages -->
                    <div t-if="message == 'cant_approve'" class="alert alert-danger alert-dismissable d-print-none" role="alert">
                        <button type="button" class="close" data-dismiss="alert" aria-label="Close">&amp;times;</button>
                        Your Project is not in a state to be approved.
                    </div>

                    <div t-if="message == 'sign_ok'" class="alert alert-success alert-dismissable d-print-none" role="status">
                        <button type="button" class="close" data-dismiss="alert" aria-label="Close">&amp;times;</button>
                        <strong>Thank You!</strong><br/>
                        <t t-if="message == 'sign_ok' and project_task.approval_state == 'approved'">Your Project has been confirmed.</t>
                    </div>

                    <div t-if="message == 'cant_reject'" class="alert alert-danger alert-dismissable d-print-none" role="alert">
                        <button type="button" class="close" data-dismiss="alert" aria-label="Close">&amp;times;</button>
                        Your Project is not in a state to be rejected.
                    </div>

                    <div t-if="project_task.approval_state == 'rejected'" class="alert alert-danger alert-dismissable d-print-none" role="alert">
                        <button type="button" class="close" data-dismiss="alert" aria-label="close">&amp;times;</button>
                        <strong>This Project has been rejected.</strong>
                    </div>

                    <!-- main content -->
                    <div t-attf-class="card #{'pb-5' if report_type == 'html' else ''}">
                        <div t-call="project_custom.project_task_portal_content"/>
                    </div>

                    <!-- bottom actions -->
                    <div t-if="project_task.display_confirm()" class="row justify-content-center text-center d-print-none pt-1 pb-4">
                    <!-- <div class="row justify-content-center text-center d-print-none pt-1 pb-4"> -->
                        <t>
                            <div class="col-sm-auto mt8">
                                <a role="button" class="btn btn-primary" data-toggle="modal" data-target="#modalaccept" href="#"><i class="fa fa-check"/> Accept</a>
                            </div>
                            <div class="col-sm-auto mt8">
                                <a role="button" class="btn btn-secondary" href="#discussion"><i class="fa fa-comment"/> Feedback</a>
                            </div>
                            <div class="col-sm-auto mt8">
                                <a role="button" class="btn btn-danger" data-toggle="modal" data-target="#modaldecline" href="#"> <i class="fa fa-times"/> Reject</a>
                            </div>
                        </t>
                    </div>

                    <!-- chatter -->
                    <div id="project_task_communication" class="mt-4">
                        <h2>History</h2>
                        <t t-call="portal.message_thread">
                            <t t-set="object" t-value="project_task"/>
                        </t>
                    </div>
                </div><!-- // #project_task_approval_content -->
            </div>
        </xpath>
    </template>

    <!--
    Payment Account content : intro, informations, remarks, descriptions ....
    This template should contains all the printable element of the SO. This is the
    template rendered in PDF with the report engine.
    -->
    <template id="project_task_portal_content" name="Project Task Portal Content" >
        <!-- Intro -->
        <div id="introduction" t-attf-class="pb-2 pt-3 #{'card-header bg-white' if report_type == 'html' else ''}">
            <h2 class="my-0">
                <em t-field="project_task.name"/> - 
                <em t-esc="project_task.name_seq"/>
            </h2>
        </div>

        <div t-attf-class="#{'card-body' if report_type == 'html' else ''}">
            <div id="informations">
                <div class="mb-3 col-12">
                    <div class="row">
                        <div class="col-12">
                            <div class="text-left">
                                <p><strong>Tên Hội Thánh: <span t-esc="project_task.partner_id.name"></span></strong></p>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12">
                            <div class="text-left">
                                <p>Địa chỉ: <span t-esc="project_task.partner_id.street"></span></p>
                            </div>
                        </div>
                        
                    </div>
                    <div class="row">
                        <div class="col-6">
                            <div class="text-left">
                                <p>Số điện thoại: <span t-esc="project_task.partner_id.phone"></span></p>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="text-left">
                                <p>Email: <span t-esc="project_task.partner_id.email"></span></p>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12">
                            <div class="text-left">
                                <p><strong>Ý KIẾN CỦA BAN CHẤP SỰ - BAN XÂY DỰNG</strong></p>
                            </div>
                            <div class="text-left">
                                <p><span t-esc="project_task.opinion_deacon_board"></span></p>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12">
                            <div class="text-left">
                                <p><strong>Ý KIẾN CỦA BAN TƯ VẤN</strong></p>
                            </div>
                            <div class="text-left">
                                <p><span t-esc="project_task.opinion_advisor"></span></p>
                            </div>
                        </div>
                    </div>
                    <div t-if="project_task.opinion_pastor" class="row">
                        <div class="col-12">
                            <div class="text-left">
                                <p><strong>Ý KIẾN CỦA MỤC SƯ QUẢN NHIỆM</strong></p>
                            </div>
                            <div class="text-left">
                                <p><span t-esc="project_task.opinion_pastor"></span></p>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12">
                            <div class="text-left">
                                <p><strong><i>Vui lòng xem hồ sơ đính kèm bên dưới để duyệt nội bộ</i></strong></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </template>
</odoo>
