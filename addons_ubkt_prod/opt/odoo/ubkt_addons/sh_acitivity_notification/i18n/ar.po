"\n"
"            \n"
"            <p>عزيزي ${object.create_uid.partner_id.name},\n"
"            </p>\n"
"\t\t\t<p>\n"
"\t\t\t\tنشاطك # ${object.activity_type_id.name} \n"
"\t\t\t\t% if object.summary \n"
"\t\t\t\t\"${object.summary}\"\n"
"\t\t\t\t% endif\n"
"\t\t\t\tمن المقرر في ${object.date_deadline} مستحق.\n"
"\t\t\t</p>\n"
"\t\t\t\n"
"\t\t\t<p>\t\n"
