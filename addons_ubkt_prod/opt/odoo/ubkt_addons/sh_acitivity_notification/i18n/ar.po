msgid ""
"\n"
"            \n"
"            <p>Dear ${object.create_uid.partner_id.name},\n"
"            </p>\n"
"\t\t\t<p>\n"
"\t\t\t\tYour Activity # ${object.activity_type_id.name} \n"
