<?xml version="1.0" encoding="utf-8"?>
<odoo><data noupdate="1">
    <template id="mail_notification_approve_online" inherit_id="mail.mail_notification_paynow" name="Approve: Sign and Pay mail notification template">
        
        <xpath expr="//td[@style='padding: 0']" position="replace">
            <t t-if="record._name in ('account.payment', 'project.task')">
                <t t-if="record._name == 'account.payment'">
                    <td style="padding: 0">
                        <t t-out="message.body"/>
                        <div style="margin: 32px 0px 32px 0px; text-align: center;">
                            <a t-att-href="access_url"
                                style="background-color: #875A7B; padding: 8px 16px 8px 16px; text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;">
                                <!-- <t t-esc="access_name"> Review, Accept &amp; Sign Quotation</t> -->
                                <t> Review, Approve &amp; Sign Payment</t>
                            </a>
                        </div>

                        <t t-if="'user_id' in record and record.user_id and not record.env.user._is_superuser()">
                            <div style="margin: 0px; padding: 0px; font-size:13px;">
                                Best regards,
                            </div>
                            <div>&amp;nbsp;</div>
                            <div t-if="record.user_id.sudo().signature" style="font-size: 13px;">
                                <div t-out="record.user_id.sudo().signature"/>
                            </div>
                        </t>
                    </td>
                </t>
                <t t-if="record._name == 'project.task'">
                    <td style="padding: 0">
                        <t t-out="message.body"/>
                        <!-- Only the pastor -->
                        <t t-if="record.stage_id.id == 68">
                            <div style="margin: 32px 0px 32px 0px; text-align: center;">
                                <a t-att-href="access_url"
                                    style="background-color: #875A7B; padding: 8px 16px 8px 16px; text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;">
                                    <t> Review &amp; Approve</t>
                                </a>
                            </div>
                        </t>

                        <t t-if="'user_id' in record and record.user_id and not record.env.user._is_superuser()">
                            <div style="margin: 0px; padding: 0px; font-size:13px;">
                                Best regards,
                            </div>
                            <div>&amp;nbsp;</div>
                            <div t-if="record.user_id.sudo().signature" style="font-size: 13px;">
                                <div t-out="record.user_id.sudo().signature"/>
                            </div>
                        </t>
                    </td>
                </t>
            </t>
            <t t-else="">
                <td style="padding: 0">
                    <t t-out="message.body"/>
                    <div t-if="is_online and not record._context.get('proforma')" style="margin: 32px 0px 32px 0px; text-align: center;">
                        <a t-att-href="access_url"
                            style="background-color: #875A7B; padding: 8px 16px 8px 16px; text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;">
                            <t t-esc="access_name"/>
                        </a>
                    </div>
                    <t t-if="'user_id' in record and record.user_id and not record.env.user._is_superuser()">
                        <div style="margin: 0px; padding: 0px; font-size:13px;">
                            Best regards,
                        </div>
                        <div>&amp;nbsp;</div>
                        <div t-if="record.user_id.sudo().signature" style="font-size: 13px;">
                            <div t-out="record.user_id.sudo().signature"/>
                        </div>
                    </t>
                </td>
            </t>t>
        </xpath>
        
    </template>
</data></odoo>
