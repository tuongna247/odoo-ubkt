<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="email_template_account_approval" model="mail.template">
            <field name="name">Payment Receipt: Send to approval</field>
            <field name="model_id" ref="account_custom.model_account_payment"/>
            <field name="subject">{{ object.company_id.name }} Payment Receipt (Ref {{ object.name_seq or 'n/a' }})</field>
            <field name="partner_to">{{ object.approval_id.partner_id.id }}</field>
            <!-- <field name="email_to">{{ object.approval_id.id }}</field> -->
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        Dear <t t-out="object.approval_id.name or ''">Azure Interior</t><br/><br/>
        Thank you for your payment.
        Here is your payment receipt <strong t-out="(object.name_seq or '').replace('/','-') or ''">BNK1-2021-05-0002</strong> amounting
        to <strong t-out="format_amount(object.amount, object.currency_id) or ''">$ 10.00</strong> from <t t-out="object.company_id.name or ''">YourCompany</t>.
        <br /><br />
        Do not hesitate to contact us if you have any questions.
    </p>
</div>
</field>
            <field name="report_template" ref="account_custom.action_report_account_payment"/>
            <field name="report_name">{{ (object.name_seq or '').replace('/','-') }}</field>
            <field name="lang">{{ object.approval_id.lang }}</field>
            <field name="auto_delete" eval="True"/>
        </record>

        <record id="email_template_account_approval_confirm" model="mail.template">
            <field name="name">Payment Receipt: approval confirm</field>
            <field name="model_id" ref="account_custom.model_account_payment"/>
            <field name="subject">{{ object.company_id.name }} Payment Receipt (Ref {{ object.name_seq or 'n/a' }})</field>
            <field name="partner_to">{{ object.approval_id.partner_id.id }}</field>
            <!-- <field name="email_to">{{ object.approval_id.id }}</field> -->
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        The payment receipt <strong t-out="(object.name_seq or '').replace('/','-') or ''">BNK1-2021-05-0002</strong> is approved by 
        <strong t-out="object.approval_id.name or ''">Azure Interior</strong>
    </p>
</div>
</field>
            <field name="report_template" ref="account_custom.action_report_account_payment"/>
            <field name="report_name">Final_{{ (object.name_seq or '').replace('/','-') }}</field>
            <field name="lang">{{ object.approval_id.lang }}</field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>
