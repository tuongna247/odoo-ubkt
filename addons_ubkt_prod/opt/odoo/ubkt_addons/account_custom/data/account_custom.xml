<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
        Account Payment Sequences
        -->
        <record id="account_payment_receive_seq" model="ir.sequence">
            <field name="name">Account payment Receive sequence</field>
            <field name="code">account.payment.receive</field>
            <field name="prefix">BN%(day)s-%(month)s-%(year)s-</field>
            <field name="padding">3</field>
            <field name="use_date_range">True</field>
            <field eval="1" name="number_next"/>
            <field eval="1" name="number_increment"/>
            <field eval="False" name="company_id"/>
        </record>
        <record id="account_payment_send_seq" model="ir.sequence">
            <field name="name">Account payment Send sequence</field>
            <field name="code">account.payment.send</field>
            <field name="prefix">PC%(day)s-%(month)s-%(year)s-</field>
            <field name="padding">3</field>
            <field name="use_date_range">True</field>
            <field eval="1" name="number_next"/>
            <field eval="1" name="number_increment"/>
            <field eval="False" name="company_id"/>
        </record>
    </data>
</odoo>
