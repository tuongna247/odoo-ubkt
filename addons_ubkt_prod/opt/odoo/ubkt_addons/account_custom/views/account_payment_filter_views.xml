<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_account_payment_filter_extend" model="ir.ui.view">
            <field name="name">account.payment.select.extend</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_search"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_id']" position="before">
                    <field name="project_task_id" filter_domain="[('project_task_id', 'ilike', self)]"/>
                    <field name="name_seq" filter_domain="[('name_seq', 'ilike', self)]"/>
                </xpath>
                <xpath expr="//field[@name='name']" position="replace">
                    <field name="name" string="Payment" invisible="1"
                        filter_domain="['|', '|', ('name', 'ilike', self), ('partner_id', 'ilike', self), ('ref', 'ilike', self)]"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
