<odoo>
    <template id="portal_my_home_payment_approval" name="Show Payment Approvals" inherit_id="portal.portal_my_home" customize_show="True" priority="30">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Payment Approvals</t>
                <t t-set="url" t-value="'/my/payment_approvals'"/>
                <t t-set="placeholder_count" t-value="'payment_approval_count'"/>
            </t>
        </xpath>
    </template>

    <template id="portal_my_payment_approvals" name="My Payment Approvals">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">Payment Approvals</t>
            </t>
            <t t-if="payment_approvals" t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>Payment Approval #</th>
                        <th class="text-right">Payment Approval Date</th>
                        <th class="text-right"></th>
                        <th class="text-right">Total</th>
                    </tr>
                </thead>
                <t t-foreach="payment_approvals" t-as="quotation">
                    <tr>
                        <td><a t-att-href="quotation.get_portal_url()"><t t-esc="quotation.name_seq"/></a></td>
                        <td class="text-right"><span t-field="quotation.date"/></td>
                        <td>
                        <t t-if="quotation.state in ('draft', 'sent')">
                            <span class="badge badge-pill badge-info"><i class="fa fa-fw fa-clock-o" aria-label="Opened" title="Opened" role="img"></i><span class="d-none d-md-inline"> Waiting for Confirm</span></span>
                        </t>
                        <t t-if="quotation.state in ('posted')">
                            <span class="badge badge-pill badge-info"><i class="fa fa-fw fa-clock-o" aria-label="Opened" title="Opened" role="img"></i><span class="d-none d-md-inline"> Posted</span></span>
                        </t>
                        </td>
                        <td class="text-right">
                            <span t-field="quotation.amount"/>
                        </td>
                    </tr>
                </t>
            </t>
        </t>
    </template>

    <!-- View approval page of the account_payment -->
    <template id="account_payment_portal_template" name="Account Payment Portal Template" inherit_id="portal.portal_sidebar" primary="True">
        <xpath expr="//div[hasclass('o_portal_sidebar')]" position="inside">
            <!-- <t t-set="o_portal_fullwidth_alert" groups="sales_team.group_sale_salesman"> -->
            <t t-set="o_portal_fullwidth_alert"> 
                <t t-call="portal.portal_back_in_edit_mode">
                    <t t-set="backend_url" t-value="'/web#model=%s&amp;id=%s&amp;action=%s&amp;view_type=form' % (account_payment._name, account_payment.id, action.id)"/>
                </t>
            </t>

            <div class="row mt16 o_portal_invoice_sidebar">
                <!-- Sidebar -->
                <t t-call="portal.portal_record_sidebar">
                    <t t-set="classes" t-value="'col-lg-auto d-print-none'"/>

                    <t t-set="title">
                        <h2 class="mb-0"><b t-field="account_payment.amount_total" data-id="total_amount"/> </h2>
                    </t>
                    <t t-set="entries">
                        <ul class="list-group list-group-flush flex-wrap flex-row flex-lg-column">
                            <li class="list-group-item flex-grow-1">
                                <t t-if="account_payment.display_confirm()">
                                    <a role="button" class="btn btn-primary btn-block mb8" data-toggle="modal" data-target="#modalaccept" href="#">
                                        <i class="fa fa-check"/><t> Accept &amp; Sign</t>
                                    </a>
                                </t>
                                <div class="o_download_pdf btn-toolbar flex-sm-nowrap">
                                    <div class="btn-group flex-grow-1 mr-1 mb-1">
                                        <a class="btn btn-secondary btn-block o_download_btn" t-att-href="account_payment.get_portal_url(report_type='pdf', download=True)" title="Download"><i class="fa fa-download"/> Download</a>
                                    </div>
                                    <div class="btn-group flex-grow-1 mb-1">
                                        <a class="btn btn-secondary btn-block o_print_btn o_portal_invoice_print" t-att-href="account_payment.get_portal_url(report_type='pdf')" id="print_invoice_report" title="Print" target="_blank"><i class="fa fa-print"/> Print</a>
                                    </div>
                                </div>
                            </li>

                            <li class="navspy list-group-item pl-0 flex-grow-1" t-ignore="true" role="complementary">
                                <ul class="nav flex-column bs-sidenav"></ul>
                            </li>

                            <li t-if="account_payment.user_id" class="list-group-item flex-grow-1">
                                <div class="small mb-1"><strong class="text-muted">Salesperson</strong></div>
                                <div class="row flex-nowrap">
                                    <div class="col flex-grow-0 pr-2">
                                        <img class="rounded-circle mr4 float-left o_portal_contact_img" t-if="account_payment.user_id.image_1024" t-att-src="image_data_uri(account_payment.user_id.image_1024)" alt="Contact"/>
                                        <img class="rounded-circle mr4 float-left o_portal_contact_img" t-if="not account_payment.user_id.image_1024" src="/web/static/src/img/placeholder.png" alt="Contact"/>
                                    </div>
                                    <div class="col pl-0" style="min-width: 150px">
                                        <span t-field="account_payment.user_id" t-options='{"widget": "contact", "fields": ["name", "phone"], "no_marker": True}'/>
                                        <a href="#discussion" class="small"><i class="fa fa-comment"></i> Send message</a>
                                    </div>
                                </div>
                            </li>
                        </ul>
                    </t>
                </t>

                <!-- Page content -->
                <div id="account_payment_approval_content" class="col-12 col-lg justify-content-end">

                    <!-- modal relative to the actions sign and pay -->
                    <div role="dialog" class="modal fade" id="modalaccept">
                        <div class="modal-dialog" t-if="account_payment.has_to_be_signed(True)">
                            <!-- <form id="decline" method="POST" t-attf-action="/my/account_payments/#{account_payment.id}/decline?access_token=#{account_payment.access_token}" class="modal-content"></form> -->
                            <form id="accept" method="POST" t-attf-action="/my/account_payments/#{account_payment.id}/accept?access_token=#{account_payment.access_token}" class="modal-content">
                            <!-- <form id="accept" method="POST" t-att-data-order-id="account_payment.id" t-att-data-token="account_payment.access_token" class="js_accept_json modal-content js_website_submit_form"> -->
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <header class="modal-header">
                                    <h4 class="modal-title">Payment Approval</h4>
                                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">×</button>
                                </header>
                                <main class="modal-body" id="sign-dialog">
                                    <p>
                                        <span>By clicking Accept &amp; Sign, I agree to the following terms:</span>
                                        <ul>
                                            <li><span>Accepted on the behalf of:</span> <b t-field="account_payment.approval_id.name"/></li>
                                            <li><span>For an amount of:</span> <b data-id="total_amount" t-field="account_payment.amount_total"/></li>
                                        </ul>
                                    </p>
                                    <!-- <t t-call="portal.signature_form">
                                        <t t-set="call_url" t-value="account_payment.get_portal_url(suffix='/accept')"/>
                                        <t t-set="default_name" t-value="account_payment.approval_id.name"/>
                                    </t> -->
                                    <footer class="modal-footer">
                                        <button type="submit" t-att-id="account_payment.id" class="btn btn-primary" data-toggle="modal" data-target="#modalaccept"><i class="fa fa-check"></i> Accept &amp; Sign</button>
                                        <button type="button" class="btn btn-primary" data-dismiss="modal">Cancel</button>
                                    </footer>
                                </main>
                            </form>
                        </div>
                    </div>

                    <!-- modal relative to the action reject -->
                    <div role="dialog" class="modal fade" id="modaldecline">
                        <div class="modal-dialog">
                            <form id="decline" method="POST" t-attf-action="/my/account_payments/#{account_payment.id}/decline?access_token=#{account_payment.access_token}" class="modal-content">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <header class="modal-header">
                                    <h4 class="modal-title">Reject This Payment Approval</h4>
                                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">&amp;times;</button>
                                </header>
                                <main class="modal-body">
                                    <p>
                                        Tell us why you are refusing this Payment Approval, this will help us improve our services.
                                    </p>
                                    <textarea rows="4" name="decline_message" required="" placeholder="Your feedback..." class="form-control" />
                                </main>
                                <footer class="modal-footer">
                                    <button type="submit" t-att-id="account_payment.id" class="btn btn-danger"><i class="fa fa-times"></i> Reject</button>
                                    <button type="button" class="btn btn-primary" data-dismiss="modal">Cancel</button>
                                </footer>
                            </form>
                        </div>
                    </div>

                    <!-- status messages -->
                    <div t-if="message == 'sign_ok'" class="alert alert-success alert-dismissable d-print-none" role="status">
                        <button type="button" class="close" data-dismiss="alert" aria-label="Close">&amp;times;</button>
                        <strong>Thank You!</strong><br/>
                        <t t-if="message == 'sign_ok' and account_payment.state in ['purchase', 'done']">Your Account Payment has been confirmed.</t>
                    </div>

                    <div t-if="message == 'cant_reject'" class="alert alert-danger alert-dismissable d-print-none" role="alert">
                        <button type="button" class="close" data-dismiss="alert" aria-label="Close">&amp;times;</button>
                        Your Account Payment is not in a state to be rejected.
                    </div>

                    <div t-if="account_payment.state == 'cancel'" class="alert alert-danger alert-dismissable d-print-none" role="alert">
                        <button type="button" class="close" data-dismiss="alert" aria-label="close">&amp;times;</button>
                        <strong>This Payment Approval has been canceled.</strong> <a role="button" href="#discussion"><i class="fa fa-comment"/> Contact us to get a new Payment Approval.</a>
                    </div>

                    <!-- main content -->
                    <div t-attf-class="card #{'pb-5' if report_type == 'html' else ''}">
                        <div t-call="account_custom.account_payment_portal_content"/>
                    </div>

                    <!-- bottom actions -->
                    <div t-if="account_payment.display_confirm()" class="row justify-content-center text-center d-print-none pt-1 pb-4">
                    <!-- <div class="row justify-content-center text-center d-print-none pt-1 pb-4"> -->
                        <t>
                            <div class="col-sm-auto mt8">
                                <a role="button" class="btn btn-primary" data-toggle="modal" data-target="#modalaccept" href="#"><i class="fa fa-check"/> Accept &amp; Sign</a>
                            </div>
                            <div class="col-sm-auto mt8">
                                <a role="button" class="btn btn-secondary" href="#discussion"><i class="fa fa-comment"/> Feedback</a>
                            </div>
                            <div class="col-sm-auto mt8">
                                <a role="button" class="btn btn-danger" data-toggle="modal" data-target="#modaldecline" href="#"> <i class="fa fa-times"/> Reject</a>
                            </div>
                        </t>
                    </div>

                    <!-- chatter -->
                    <div id="account_payment_communication" class="mt-4">
                        <h2>History</h2>
                        <t t-call="portal.message_thread">
                            <t t-set="object" t-value="account_payment"/>
                        </t>
                    </div>
                </div><!-- // #account_payment_approval_content -->
            </div>
        </xpath>
    </template>

    <!--
    Payment Account content : intro, informations, remarks, descriptions ....
    This template should contains all the printable element of the SO. This is the
    template rendered in PDF with the report engine.
    -->
    <template id="account_payment_portal_content" name="Account Payment Portal Content" >
        <!-- Intro -->
        <div id="introduction" t-attf-class="pb-2 pt-3 #{'card-header bg-white' if report_type == 'html' else ''}">
            <h2 class="my-0">
                <em t-field="account_payment.type_name"/>
                <em t-esc="account_payment.name_seq"/>
            </h2>
        </div>

        <t t-if="account_payment.payment_type == 'inbound'">
            <div id="wrap" class="oe_structure oe_empty">
                <section class="s_three_columns pt32 pb32 o_colored_level" data-vcss="001" data-snippet="s_three_columns" data-name="Columns" style="">
                    <div class="container">
                      <div class="row d-flex align-items-start">
                        <p t-if="account_payment.signature and account_payment.approval_id.sign_stamp_send" id="signature_stamp_pay_send" name="signature_stamp_pay_send">
                            <div class="s_col_no_bgcolor pt0 pb0 col-lg-7" style="padding-left:3rem;">
                                <div class="card bg-white h-100 rounded border" style="border-radius: 0px !important; border-width: 0px !important;">
                                  <img t-att-src="image_data_uri(account_payment.approval_id.sign_stamp_send)" style="margin:0;max-height: 25rem; max-width: 27rem;"/>
                                </div>
                            </div>
                        </p>
                        <p t-else="">
                            <div class="s_col_no_bgcolor pt0 pb0 col-lg-7" style="padding-left:3rem;">
                                <div class="card bg-white h-100 rounded border" style="border-radius: 0px !important; border-width: 0px !important;">
                                  <img src="/account_custom/static/img/header_phieuchi.png" alt="" loading="lazy" data-original-title="" title="" data-mimetype="image/png" style="margin:0;max-height: 25rem; max-width: 27rem;"/>
                                </div>
                            </div>
                        </p>
                        
                        <div class="s_col_no_bgcolor pb0 pt0 col-lg-5">
                          <div class="text-right" style="padding-right:2rem;">
                            Mã Phiếu: <span t-esc="account_payment.paper_payment_code"></span><br></br>
                            Số: <span t-esc="account_payment.name_seq"></span>/UBKT.TLH
                          </div>
                        </div>
                      </div>
                    </div>
                </section>
                <section>
                    <div class="text-center" style="font-size: 38px !important;font-weight: bold !important;">
                        BIÊN NHẬN
                    </div>
                </section>
                <section class="s_text_block o_colored_level pb0 pt0" data-snippet="s_text_block" data-name="Text" style="background-image: none;">
                    <div class="s_allow_columns o_container_small" style="font-size: 18px !important;">
                        <ul>
                          <li>Nhận của: <span t-esc="account_payment.benefactor_id.name"></span></li>
                          <li>Số tiền: <span t-esc="account_payment.format_quantity(account_payment.amount, 0)"></span> VND</li>
                          <li>Viết bằng chữ: <span t-esc="account_payment.translate_money_string(account_payment.amount)"></span></li>
                          <li>Dâng về việc: <span t-esc="account_payment.description"></span></li>
                        </ul>
                    </div>
                </section>
                <section>
                    <div style="text-align: right;font-size: 18px !important;">
                        TP. Hồ Chí Minh, <span t-field="account_payment.date" t-options='{"widget": "date", "format": "dd/MM/yyyy"}'/>&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&amp;nbsp;
                    </div>
                </section>
                <section class="s_three_columns pb32 o_colored_level pt0" data-vcss="001" data-snippet="s_three_columns" data-name="Columns" style="background-image: none;">
                    <div class="container">
                        <div class="row d-flex align-items-stretch" style="font-size: 18px !important;font-weight: bold !important;">
                          <div class="s_col_no_bgcolor pb16 pt0 col-lg-5">
                            <div style="border-width: 0px !important;text-align: center;">
                                CHUYÊN TRÁCH UBKT-TLH
                            </div>
                          </div>
                          <div class="s_col_no_bgcolor pb16 col-lg-3 pt0">
                            <div style="border-width: 0px !important;text-align: left;">
                                Người giao tiền
                            </div>
                          </div>
                          <div class="s_col_no_bgcolor pb16 col-lg-4 pt0">
                            <div style="border-width: 0px !important;text-align: center;padding-right:3rem;">
                                Người nhận tiền
                            </div>
                          </div>
                        </div>
                        <p t-if="account_payment.signature" id="signature_pay_send" name="signature_pay_send">
                            <div class="row d-flex align-items-stretch">
                                <div class="s_col_no_bgcolor pb16 pt0 col-lg-4">
                                    <div style="border-width: 0px !important;text-align: right;padding-left:3rem;">
                                        <img t-att-src="image_data_uri(account_payment.approval_id.sign_signature)" style="max-width: 14rem;"/>
                                    </div>
                                </div>
                                <div class="s_col_no_bgcolor pb16 col-lg-4 pt0">
                                    <div style="border-width: 0px !important;text-align: center;">
                                        <img t-att-src="image_data_uri(account_payment.accountant_id.sign_signature)" style="max-width: 14rem;"/>
                                    </div>
                                </div>
                                <div class="s_col_no_bgcolor pb16 col-lg-4 pt0">
                                    <div style="border-width: 0px !important;text-align: center;">
                                        <img t-att-src="image_data_uri(account_payment.treasurer_id.sign_signature)" style="max-width: 14rem;"/>
                                    </div>
                                </div>
                            </div>
                        </p>
                    </div>
                </section>
            </div>
        </t>
        <t t-else=""> <!-- PC -->
            <div id="wrap" class="oe_structure oe_empty">
                <section class="s_three_columns pt32 pb32 o_colored_level" data-vcss="001" data-snippet="s_three_columns" data-name="Columns" style="">
                    <div class="container">
                      <div class="row d-flex align-items-start">
                        <p t-if="account_payment.signature and account_payment.approval_id.sign_stamp_send" id="signature_stamp_pay_send" name="signature_stamp_pay_send">
                            <div class="s_col_no_bgcolor pt0 pb0 col-lg-7" style="padding-left:3rem;">
                                <div class="card bg-white h-100 rounded border" style="border-radius: 0px !important; border-width: 0px !important;">
                                  <img t-att-src="image_data_uri(account_payment.approval_id.sign_stamp_send)" style="margin:0;max-height: 25rem; max-width: 27rem;"/>
                                </div>
                            </div>
                        </p>
                        <p t-else="">
                            <div class="s_col_no_bgcolor pt0 pb0 col-lg-7" style="padding-left:3rem;">
                                <div class="card bg-white h-100 rounded border" style="border-radius: 0px !important; border-width: 0px !important;">
                                  <img src="/account_custom/static/img/header_phieuchi.png" alt="" loading="lazy" data-original-title="" title="" data-mimetype="image/png" style="margin:0;max-height: 25rem; max-width: 27rem;"/>
                                </div>
                            </div>
                        </p>
                        
                        <div class="s_col_no_bgcolor pb0 pt0 col-lg-5">
                          <div class="text-right" style="padding-right:2rem;">
                            Mã Phiếu: <span t-esc="account_payment.paper_payment_code"></span><br></br>
                            Số: <span t-esc="account_payment.name_seq"></span>/UBKT.TLH
                          </div>
                        </div>
                      </div>
                    </div>
                </section>
                <section>
                    <div class="text-center" style="font-size: 38px !important;font-weight: bold !important;">
                        PHIẾU CHI
                    </div>
                </section>
                <section class="s_text_block o_colored_level pb0 pt0" data-snippet="s_text_block" data-name="Text" style="background-image: none;">
                    <div class="s_allow_columns o_container_small" style="font-size: 18px !important;">
                      <ul>
                        <li>Họ, tên người nhận: <span t-esc="account_payment.received_person_text"></span></li>
                        <li>Lý do chi: <span t-esc="account_payment.description"></span></li>
                        <li>Số tiền: <span t-esc="account_payment.format_quantity(account_payment.amount, 0)"></span> VND</li>
                        <li>Viết bằng chữ: <span t-esc="account_payment.translate_money_string(account_payment.amount)"></span></li>
                        <li>Kèm theo ............................................. chứng từ gốc</li>
                      </ul>
                    </div>
                </section>
                <section>
                    <div style="text-align: right;font-size: 18px !important;">
                        TP. Hồ Chí Minh, <span t-field="account_payment.date" t-options='{"widget": "date", "format": "dd/MM/yyyy"}'/>&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&amp;nbsp;
                    </div>
                </section>
                <section class="s_three_columns pb32 o_colored_level pt0" data-vcss="001" data-snippet="s_three_columns" data-name="Columns" style="background-image: none;">
                    <div class="container">
                        <div class="row d-flex align-items-stretch" style="font-size: 18px !important;font-weight: bold !important;">
                          <div class="s_col_no_bgcolor pb16 pt0 col-lg-5">
                            <div style="border-width: 0px !important;text-align: center;">
                                CHUYÊN TRÁCH UBKT-TLH
                            </div>
                          </div>
                          <div class="s_col_no_bgcolor pb16 col-lg-3 pt0">
                            <div style="border-width: 0px !important;text-align: left;">
                                Người giao tiền
                            </div>
                          </div>
                          <div class="s_col_no_bgcolor pb16 col-lg-4 pt0">
                            <div style="border-width: 0px !important;text-align: center;padding-right:3rem;">
                                Người nhận tiền
                            </div>
                          </div>
                        </div>
                        <p t-if="account_payment.signature" id="signature_pay_send" name="signature_pay_send">
                            <div class="row d-flex align-items-stretch">
                                <div class="s_col_no_bgcolor pb16 pt0 col-lg-4">
                                    <div style="border-width: 0px !important;text-align: right;padding-left:3rem;">
                                        <img t-att-src="image_data_uri(account_payment.approval_id.sign_signature)" style="max-width: 14rem;"/>
                                    </div>
                                </div>
                                <div class="s_col_no_bgcolor pb16 col-lg-4 pt0">
                                    <div style="border-width: 0px !important;text-align: center;padding-left:3rem;">
                                        <img t-att-src="image_data_uri(account_payment.delivered_person.sign_signature)" style="max-width: 14rem;"/>
                                    </div>
                                </div>
                                <div class="s_col_no_bgcolor pb16 col-lg-4 pt0">
                                    <div style="border-width: 0px !important;text-align: center;padding-right:3rem;">
                                        <img t-att-src="image_data_uri(account_payment.received_person.sign_signature)" style="max-width: 14rem;"/>
                                    </div>
                                </div>
                            </div>
                        </p>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>
