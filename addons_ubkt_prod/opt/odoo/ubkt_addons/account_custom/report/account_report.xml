<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_report_account_payment" model="ir.actions.report">
            <field name="name">Account Payment</field>
            <field name="model">account.payment</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">account_custom.report_account_payment</field>
            <field name="report_file">account_custom.report_account_payment</field>
            <field name="print_report_name">(object.state in ('draft', 'sent'))</field>
            <field name="binding_model_id" ref="model_account_payment"/>
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="account_custom.paperformat_account_custom"/>
        </record>
    </data>
</odoo>
